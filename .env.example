# MotherDuck connection
# Get your token from https://app.motherduck.com/token-request
MOTHERDUCK_TOKEN=your_motherduck_token_here

# MotherDuck database name (created at https://app.motherduck.com)
MOTHERDUCK_DATABASE=tirana_transit

# Dagster home directory (local dev)
DAGSTER_HOME=/opt/dagster/dagster_home

# Raw data directory
RAW_DATA_DIR=/data/raw
